{
  "provider": "openai",
  "model": "gpt-5.4-mini",
  "model_price_tier": "standard",
  "max_steps": 8,
  "loop_guard": true,
  "temperature": 0.2,
  "context_size": 3,
  "verbose_system": false,
  "timeout_ms": 30000,
  "max_completion_tokens": 500,
  "retry": {"enabled": true, "max_attempts": 2, "backoff_ms": 150},
  "cache": {"enabled": true},
  "normalize_unicode": true,
  "redact_pii": true,
  "session_drift_rate": 0.0,
  "context_reset_every": 4,
  "tool_error_rate": 0.0,
  "catalog_override": {},
  "route_rules": [],
  "planner": true,
  "verify": true,
  "self_consistency": 2,
  "tool_budget": 4
}
